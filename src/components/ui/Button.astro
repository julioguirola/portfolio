---
export interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  children: any;
}

const { href, variant = 'primary' } = Astro.props;

const base = 'inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-lg transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent';
const variants = {
  primary: 'bg-accent text-white hover:bg-accent-hover shadow-sm hover:shadow',
  secondary: 'border border-border text-text hover:border-accent hover:text-accent bg-surface',
};
---

<a href={href} class={`${base} ${variants[variant]}`}>
  <slot />
</a>
