---
import SocialLink from '../ui/SocialLink.astro';
import Button from '../ui/Button.astro';

const mailLink = 'mailto:julioguirola03@gmail.com';
const githubUrl = 'https://github.com/julioguirola';
---

<section id="contacto" class="py-16 sm:py-20 bg-accent text-white">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 text-center">
    <span class="font-mono text-xs font-medium text-white/60 tracking-wider uppercase">
      05 — contacto
    </span>
    <h2 class="font-display text-3xl sm:text-4xl font-bold mt-2">
      ¿Trabajemos juntos?
    </h2>
    <p class="text-white/80 mt-4 max-w-lg mx-auto leading-relaxed">
      Si buscas un desarrollador backend con criterio técnico, autonomía y experiencia real
      llevando productos a producción, hablemos.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 mt-8 w-full">
      <a href={mailLink}
        class="inline-flex items-center justify-center gap-2 px-5 py-3 sm:py-2.5 text-sm font-medium rounded-lg bg-surface text-accent hover:bg-white/90 transition-all duration-200 shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white w-full sm:w-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Correo
      </a>
      <a href="https://wa.me/5352507304"
        class="inline-flex items-center justify-center gap-2 px-5 py-3 sm:py-2.5 text-sm font-medium rounded-lg border border-white/30 text-white hover:bg-white/10 hover:border-white/50 transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white w-full sm:w-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        WhatsApp
      </a>
    </div>

    <div class="flex items-center justify-center gap-6 mt-10">
      <SocialLink href={githubUrl} label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/70 hover:text-white transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </SocialLink>
    </div>
  </div>
</section>
