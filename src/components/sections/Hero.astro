---
import SocialLink from '../ui/SocialLink.astro';
import Button from '../ui/Button.astro';
---

<section class="flex items-center pt-16 pb-20">
  <div class="mx-auto max-w-5xl px-6 w-full">
    <div class="flex flex-col-reverse sm:flex-row items-center gap-12">
      <div class="flex-1 max-w-2xl">
        <div class="font-mono text-sm text-accent mb-4 flex items-center gap-2">
          <span class="text-text-muted">$</span>
          <span>~/whoami</span>
          <span class="inline-block w-2 h-4 bg-accent animate-[blink_1s_step-end_infinite]" aria-hidden="true"></span>
        </div>

        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-extrabold leading-tight text-text">
          Julio Alberto Guirola Alvarado
        </h1>

        <p class="text-xl sm:text-2xl font-medium text-text-muted mt-4 leading-relaxed">
          Desarrollador Backend — <span class="text-accent-secondary">Node.js · Go · Rust</span> Arquitecturas escalables en la nube
        </p>

        <p class="text-base text-text-muted mt-4 max-w-xl leading-relaxed">
          Más de cinco años construyendo software empresarial robusto, con experiencia adicional en frontend y DevOps.
        </p>

        <div class="flex flex-wrap items-center gap-4 mt-8">
          <Button href="#experiencia" variant="primary">Ver experiencia</Button>
          <Button href="#contacto" variant="secondary">Contactar</Button>
        </div>

        <div class="flex items-center gap-4 mt-10 pt-8 border-t border-border">
          <SocialLink href="https://github.com/julioguirola" label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </SocialLink>
        </div>
      </div>

      <div class="shrink-0">
        <div class="relative">
          <div class="absolute -inset-1 bg-linear-to-br from-accent to-accent-secondary rounded-full opacity-20 blur-sm"></div>
          <img
            src="https://github.com/julioguirola.png"
            alt="Foto de perfil de Julio Alberto Guirola Alvarado"
            class="relative w-40 h-40 sm:w-48 sm:h-48 rounded-full object-cover border-4 border-surface shadow-lg"
            width="192"
            height="192"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>
